# Data Mapping Agent Configuration
# Copy this to .env and fill in your actual values

# ============================================================================
# LLM PROVIDERS (in priority order: Gemini > Claude > Ollama)
# ============================================================================

# Google Gemini API Key (Recommended - fastest and most capable)
# Get from: https://aistudio.google.com (create an API key)
GOOGLE_API_KEY=

# Anthropic Claude API Key (Fallback 1 - excellent reasoning)
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Ollama Configuration (Fallback 2 - runs locally)
# Install: https://ollama.ai
# Run before using: ollama pull gemma2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2

# ============================================================================
# LLM PARAMETERS
# ============================================================================

# Temperature: 0.0-1.0 (lower = deterministic, higher = creative)
LLM_TEMPERATURE=0.7

# Maximum tokens per response (increase for complex mappings)
LLM_MAX_TOKENS=4096

# Request timeout in seconds
LLM_TIMEOUT=60

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# PROCESSING
# ============================================================================

# Default file encoding
DEFAULT_ENCODING=utf-8

# Maximum document size to process (MB)
MAX_DOCUMENT_SIZE_MB=100

# Chunk size for processing large files
CHUNK_SIZE=1000

# ============================================================================
# NOTES
# ============================================================================

# - At least one LLM provider must be configured
# - If no .env file exists, defaults are used (may limit functionality)
# - API keys are never logged or exposed
# - Local Ollama requires running: ollama serve
